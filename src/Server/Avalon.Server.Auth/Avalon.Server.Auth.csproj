<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>

    <ApplicationIcon>App.ico</ApplicationIcon>

    <Product>Avalon Authentication Server</Product>
    <ProductName>Avalon</ProductName>
    <ProductVersion>0.1.0</ProductVersion>

    <Version>0.1.0</Version>
    <Description>Avalon Authentication Server Executable</Description>
    <Copyright>Private</Copyright>

    <Authors>Nuno Levezinho</Authors>
    <Company>Nuno Levezinho's Games</Company>

    <AssemblyName>AvalonAuthServer</AssemblyName>
    <AssemblyVersion>0.1.0</AssemblyVersion>

    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>

    <LangVersion>latest</LangVersion>

    <SignAssembly>true</SignAssembly>

    <AssemblyOriginatorKeyFile>..\..\..\sgKey.snk</AssemblyOriginatorKeyFile>

    <PublicSign>true</PublicSign>

    <RootNamespace>Avalon.Server.Auth</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Shared\Avalon.Common\Avalon.Common.csproj"/>
    <ProjectReference Include="..\..\Shared\Avalon.Configuration\Avalon.Configuration.csproj"/>
    <ProjectReference Include="..\..\Shared\Avalon.Metrics\Avalon.Metrics.csproj"/>
    <ProjectReference Include="..\..\Shared\Avalon.Network.Packets\Avalon.Network.Packets.csproj"/>
    <ProjectReference Include="..\..\Shared\Avalon.Network.Tcp\Avalon.Network.Tcp.csproj"/>
    <ProjectReference Include="..\..\Shared\Avalon.Network\Avalon.Network.csproj"/>
    <ProjectReference Include="..\Avalon.Database.Auth\Avalon.Database.Auth.csproj"/>
    <ProjectReference Include="..\Avalon.Database\Avalon.Database.csproj"/>
    <ProjectReference Include="..\Avalon.Hosting\Avalon.Hosting.csproj"/>
    <ProjectReference Include="..\Avalon.Infrastructure\Avalon.Infrastructure.csproj"/>
    <ProjectReference Include="..\Avalon.ServiceDefaults\Avalon.ServiceDefaults.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration"/>
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder"/>
    <PackageReference Include="Microsoft.Extensions.Configuration.CommandLine"/>
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables"/>
    <PackageReference Include="Microsoft.Extensions.Configuration.Json"/>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection"/>
    <PackageReference Include="Microsoft.Extensions.Logging.Console"/>
    <PackageReference Include="Serilog.Enrichers.Thread"/>
    <PackageReference Include="Serilog.Extensions.Logging"/>
    <PackageReference Include="Serilog.Sinks.Console"/>
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\..\sgKey.snk">
      <Link>sgKey.snk</Link>
    </None>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Include="..\..\..\certs\cert-tcp.pfx" Link="cert-tcp.pfx" CopyToOutputDirectory="PreserveNewest"/>
  </ItemGroup>

</Project>
