<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
        
        <ApplicationIcon>App.ico</ApplicationIcon>

        <Product>Avalon Game Server Executable</Product>
        <ProductName>Avalon</ProductName>
        <ProductVersion>0.1.0</ProductVersion>
        
        <Version>0.1.0</Version>
        <Description>Avalon Game Server Executable</Description>
        <Copyright>Private</Copyright>
        
        <Authors>Nuno Levezinho</Authors>
        <Company>Nuno Levezinho's Games</Company>
        
        <AssemblyName>Avalon</AssemblyName>
        <AssemblyVersion>0.1.0</AssemblyVersion>
        
        <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
        
        <LangVersion>latest</LangVersion>
        
        <SignAssembly>true</SignAssembly>
        
        <AssemblyOriginatorKeyFile>..\..\..\sgKey.snk</AssemblyOriginatorKeyFile>
        
        <PublicSign>true</PublicSign>
    </PropertyGroup>

    <!--
	<ItemGroup>
		<FlatSharpSchema Include="Monster.fbs" />
	</ItemGroup>
	-->
    
    <ItemGroup>
      <ProjectReference Include="..\..\Shared\Avalon.Common\Avalon.Common.csproj" />
      <ProjectReference Include="..\..\Shared\Avalon.Configuration\Avalon.Configuration.csproj" />
      <ProjectReference Include="..\..\Shared\Avalon.Metrics\Avalon.Metrics.csproj" />
      <ProjectReference Include="..\..\Shared\Avalon.Network.Packets\Avalon.Network.Packets.csproj" />
      <ProjectReference Include="..\..\Shared\Avalon.Network.Tcp\Avalon.Network.Tcp.csproj" />
      <ProjectReference Include="..\..\Shared\Avalon.Network.Udp\Avalon.Network.Udp.csproj" />
      <ProjectReference Include="..\..\Shared\Avalon.Network\Avalon.Network.csproj" />
      <ProjectReference Include="..\Avalon.Database\Avalon.Database.csproj" />
      <ProjectReference Include="..\Avalon.Infrastructure\Avalon.Infrastructure.csproj" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="Microsoft.Extensions.Configuration" Version="8.0.0" />
      <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="8.0.1" />
      <PackageReference Include="Microsoft.Extensions.Configuration.CommandLine" Version="8.0.0" />
      <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="8.0.0" />
      <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="8.0.0" />
      <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.0" />
      <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="8.0.0" />
      <PackageReference Include="OpenTelemetry" Version="1.7.0" />
      <PackageReference Include="OpenTelemetry.AutoInstrumentation.Runtime.Managed" Version="1.2.0" />
      <PackageReference Include="OpenTelemetry.AutoInstrumentation.Runtime.Native" Version="1.2.0" />
      <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.7.0" />
      <PackageReference Include="protobuf-net" Version="3.2.30" />
      <PackageReference Include="QuixStreams.Streaming" Version="0.6.1" />
      <PackageReference Include="Serilog.Extensions.Logging" Version="8.0.0" />
      <PackageReference Include="Serilog.Sinks.Console" Version="5.0.1" />
    </ItemGroup>

    <ItemGroup>
      <None Include="..\..\..\sgKey.snk">
        <Link>sgKey.snk</Link>
      </None>
      <None Update="appsettings.json">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </None>
      <None Include="Maps\**" CopyToOutputDirectory="PreserveNewest" />
      <None Include="cert-tcp.pfx" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>

</Project>
